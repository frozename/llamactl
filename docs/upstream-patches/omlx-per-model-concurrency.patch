From 0000000000000000000000000000000000000002 Mon Sep 17 00:00:00 2001
From: Alexandre Cordeiro <alexandre.s.b.cordeiro@gmail.com>
Date: Thu, 21 May 2026 00:00:00 -0300
Subject: [PATCH] Add per-model max-concurrent-requests overrides
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Adds a per-model concurrency override on top of oMLX's existing global
`max_concurrent_requests` scheduler setting.

The change is additive:

- if `per_model_max_concurrent` is unset, behavior is unchanged;
- if a model is absent from the override map, the global cap still applies;
- the scheduler checks the override only for the model being admitted.

diff --git a/omlx/settings.py b/omlx/settings.py
index 1111111..2222222 100644
--- a/omlx/settings.py
+++ b/omlx/settings.py
@@ -216,6 +216,7 @@ class SchedulerSettings:
     max_concurrent_requests: int = 8
@@ -223,6 +224,7 @@ class SchedulerSettings:
     # GPU-layer batch fusion: requests can still queue at the HTTP layer
     # while each Metal command buffer encodes at most N sequences. This
     # is the lever for staying under Apple's GPU watchdog on small GPUs
     # under multi-model load — see notes in /Volumes/WorkSSD/repos/
     # personal/llamactl/docs/upstream-patches/.
     max_completion_batch_size: int | None = None
+    per_model_max_concurrent: dict[str, int] = field(default_factory=dict)

     def to_dict(self) -> dict[str, Any]:
         """Convert to dictionary."""
         return asdict(self)
@@ -249,6 +250,7 @@ class SchedulerSettings:
         mcb = data.get("max_completion_batch_size")
+        overrides = data.get("per_model_max_concurrent") or {}
         return cls(
             max_concurrent_requests=value,
             chunked_prefill=bool(data.get("chunked_prefill", False)),
             max_completion_batch_size=(int(mcb) if mcb is not None else None),
+            per_model_max_concurrent={
+                str(model): int(limit) for model, limit in overrides.items()
+            },
         )
@@ -959,6 +962,18 @@ class Settings:
         if (
             hasattr(args, "max_completion_batch_size")
             and args.max_completion_batch_size is not None
         ):
             self.scheduler.max_completion_batch_size = args.max_completion_batch_size
+        if (
+            hasattr(args, "per_model_max_concurrent")
+            and args.per_model_max_concurrent is not None
+        ):
+            self.scheduler.per_model_max_concurrent = (
+                args.per_model_max_concurrent
+            )

@@ -1235,10 +1250,14 @@ class Settings:
         completion_batch_size = (
             self.scheduler.max_completion_batch_size
             if self.scheduler.max_completion_batch_size is not None
             else self.scheduler.max_concurrent_requests
         )
         return SchedulerConfig(
             max_num_seqs=self.scheduler.max_concurrent_requests,
             completion_batch_size=completion_batch_size,
             chunked_prefill=self.scheduler.chunked_prefill,
+            per_model_max_concurrent=self.scheduler.per_model_max_concurrent,
             initial_cache_blocks=self.cache.initial_cache_blocks,
             paged_ssd_cache_dir=str(ssd_dir) if ssd_dir else None,
             hot_cache_only=self.cache.hot_cache_only,
             paged_ssd_cache_max_size=self.cache.get_ssd_cache_max_size_bytes(self.base_path),
             hot_cache_max_size=self.cache.get_hot_cache_max_size_bytes(),
         )

diff --git a/omlx/cli.py b/omlx/cli.py
index 3333333..4444444 100644
--- a/omlx/cli.py
+++ b/omlx/cli.py
@@ -1,6 +1,7 @@
 from __future__ import annotations

 import argparse

 from omlx.settings import SchedulerSettings

@@ -18,6 +19,46 @@ def build_parser() -> argparse.ArgumentParser:
     scheduler.add_argument(
         "--max-completion-batch-size",
         type=int,
         default=None,
     )
+    scheduler.add_argument(
+        "--per-model-max-concurrent",
+        type=_parse_per_model_max_concurrent_arg,
+        default=None,
+        metavar="MODEL=LIMIT[,MODEL=LIMIT...]",
+        help="Per-model concurrency overrides.",
+    )
     return parser

+
+def _parse_per_model_max_concurrent_arg(raw: str) -> dict[str, int]:
+    parsed: dict[str, int] = {}
+    if not raw.strip():
+        raise argparse.ArgumentTypeError("expected at least one MODEL=LIMIT pair")
+    for item in raw.split(","):
+        entry = item.strip()
+        if not entry:
+            raise argparse.ArgumentTypeError(
+                "expected MODEL=LIMIT comma-separated entries"
+            )
+        key, sep, value = entry.partition("=")
+        if not sep or not key.strip() or not value.strip():
+            raise argparse.ArgumentTypeError(
+                "expected MODEL=LIMIT comma-separated entries"
+            )
+        model = key.strip()
+        if model in parsed:
+            raise argparse.ArgumentTypeError(f"duplicate model override: {model}")
+        try:
+            parsed[model] = int(value.strip())
+        except ValueError as e:
+            raise argparse.ArgumentTypeError(
+                f"invalid limit for {model}: {value.strip()}"
+            ) from e
+    return parsed

diff --git a/omlx/scheduler.py b/omlx/scheduler.py
index 5555555..6666666 100644
--- a/omlx/scheduler.py
+++ b/omlx/scheduler.py
@@ -521,6 +521,7 @@ class SchedulerConfig:
     completion_batch_size: int = 32
     prefill_step_size: int = 2048
@@ -557,6 +558,7 @@ class SchedulerConfig:
     # Model identification (for cache isolation between different models)
     model_name: str = ""  # OpenAI API model name (e.g., "mlx-community/Llama-3.2-3B")
+    per_model_max_concurrent: dict[str, int] = field(default_factory=dict)

@@ -4265,7 +4267,22 @@ class Scheduler:
         # Track SpecPrefill: these requests must be alone (RoPE patching affects whole model)
         batch_specprefill_status: bool | None = None

-        while self.waiting and len(self.running) < self.config.max_num_seqs:
+        while self.waiting and len(self.running) < self.config.max_num_seqs:
+            request = self.waiting[0]
+            model_name = getattr(request, "model_name", "") or self.config.model_name
+            per_model_limit = self.config.per_model_max_concurrent.get(model_name)
+            if per_model_limit is not None:
+                model_running = sum(
+                    1
+                    for running_request in self.running
+                    if (getattr(running_request, "model_name", "") or self.config.model_name)
+                    == model_name
+                )
+                if model_running >= per_model_limit:
+                    break
             # Admission pause: set by ProcessMemoryEnforcer when phys
             # crosses soft_threshold. New prefills wait; in-flight requests
             # continue. First request always passes (self.running is empty)
             # so admission can recover by completing the current generation.
             if self._admission_paused and self.running:
                 logger.debug(
                     "Admission paused by memory pressure, %d running",
                     len(self.running),
                 )
                 break

diff --git a/tests/test_per_model_concurrency.py b/tests/test_per_model_concurrency.py
new file mode 100644
index 0000000..7777777
--- /dev/null
+++ b/tests/test_per_model_concurrency.py
@@ -0,0 +1,117 @@
+from __future__ import annotations
+
+import argparse
+from dataclasses import dataclass
+
+from omlx.cli import _parse_per_model_max_concurrent_arg
+from omlx.scheduler import Scheduler
+from omlx.settings import SchedulerSettings
+
+
+@dataclass
+class Request:
+    model_name: str
+
+
+def test_parse_per_model_max_concurrent_flag() -> None:
+    parsed = _parse_per_model_max_concurrent_arg("qwen3-8b=4,granite-3b=8")
+    assert parsed == {"qwen3-8b": 4, "granite-3b": 8}
+
+
+def test_parse_per_model_max_concurrent_rejects_malformed() -> None:
+    for raw in [
+        "",
+        "qwen3-8b",
+        "qwen3-8b=",
+        "=4",
+        "qwen3-8b=4,",
+        "qwen3-8b=4,granite-3b=x",
+    ]:
+        try:
+            _parse_per_model_max_concurrent_arg(raw)
+        except argparse.ArgumentTypeError:
+            pass
+        else:
+            raise AssertionError(f"expected argparse.ArgumentTypeError for {raw!r}")
+
+
+def test_scheduler_settings_round_trip() -> None:
+    settings = SchedulerSettings(
+        max_concurrent_requests=2,
+        max_completion_batch_size=1,
+        per_model_max_concurrent={"qwen3-8b": 4, "granite-3b": 8},
+    )
+    data = settings.to_dict()
+    restored = SchedulerSettings.from_dict(data)
+    assert restored.max_concurrent_requests == 2
+    assert restored.max_completion_batch_size == 1
+    assert restored.per_model_max_concurrent == {"qwen3-8b": 4, "granite-3b": 8}
+
+
+def test_scheduler_settings_apply_args_round_trip() -> None:
+    settings = SchedulerSettings()
+    args = argparse.Namespace(
+        max_concurrent_requests=None,
+        max_completion_batch_size=None,
+        per_model_max_concurrent={"qwen3-8b": 4, "granite-3b": 8},
+    )
+    settings.apply_args(args)
+    assert settings.per_model_max_concurrent == {"qwen3-8b": 4, "granite-3b": 8}
+
+
+def test_admission_honors_per_model_cap() -> None:
+    settings = SchedulerSettings(
+        max_concurrent_requests=4,
+        per_model_max_concurrent={"qwen3-8b": 1},
+    )
+    scheduler = Scheduler(settings)
+    scheduler.running = [
+        Request(model_name="qwen3-8b"),
+    ]
+    scheduler.waiting = [
+        Request(model_name="qwen3-8b"),
+        Request(model_name="granite-3b"),
+    ]
+
+    scheduled, rejected = scheduler._schedule_waiting()
+
+    assert scheduled == []
+    assert rejected == []
+    assert [req.model_name for req in scheduler.waiting] == ["qwen3-8b", "granite-3b"]
