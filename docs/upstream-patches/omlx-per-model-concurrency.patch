diff --git a/omlx/cli.py b/omlx/cli.py
index 3333333..4444444 100644
--- a/omlx/cli.py
+++ b/omlx/cli.py
@@ -1,7 +1,8 @@
 from __future__ import annotations
 
 import argparse
+from collections.abc import Sequence
 
 from omlx.settings import SchedulerSettings
 
@@ -18,6 +19,27 @@ def build_parser() -> argparse.ArgumentParser:
     scheduler.add_argument(
         "--max-completion-batch-size",
         type=int,
         default=None,
     )
+    scheduler.add_argument(
+        "--per-model-max-concurrent",
+        type=_parse_per_model_max_concurrent_arg,
+        default=None,
+        metavar="MODEL=LIMIT[,MODEL=LIMIT...]",
+        help="Per-model concurrency overrides.",
+    )
     return parser
 
+
+def _parse_per_model_max_concurrent_arg(raw: str) -> dict[str, int]:
+    parsed: dict[str, int] = {}
+    if not raw.strip():
+        return parsed
+    for item in raw.split(","):
+        key, sep, value = item.strip().partition("=")
+        if not sep or not key or not value:
+            raise argparse.ArgumentTypeError(
+                "expected MODEL=LIMIT comma-separated entries"
+            )
+        if key in parsed:
+            raise argparse.ArgumentTypeError(f"duplicate model override: {key}")
+        parsed[key] = int(value)
+    return parsed
diff --git a/omlx/scheduler.py b/omlx/scheduler.py
index 5555555..6666666 100644
--- a/omlx/scheduler.py
+++ b/omlx/scheduler.py
@@ -1,6 +1,7 @@
 from __future__ import annotations
 
 from collections import defaultdict
+from collections.abc import Callable
 
 from omlx.settings import SchedulerSettings
 
@@ -31,8 +32,24 @@ class Scheduler:
         self.settings = settings
         self.running: list[Request] = []
         self.waiting: list[Request] = []
+
+    def _model_running_count(self, model_name: str) -> int:
+        return sum(1 for req in self.running if req.model == model_name)
+
+    def can_admit(self, model_name: str) -> bool:
+        per_model_limit = self.settings.per_model_max_concurrent.get(model_name)
+        if per_model_limit is not None:
+            return self._model_running_count(model_name) < per_model_limit
+        return len(self.running) < self.settings.max_concurrent_requests
+
     def _schedule_waiting(self) -> None:
         next_waiting: list[Request] = []
         for request in self.waiting:
-            if len(self.running) < self.settings.max_concurrent_requests:
+            if self.can_admit(request.model):
                 self.running.append(request)
                 continue
             next_waiting.append(request)
         self.waiting = next_waiting
diff --git a/tests/test_per_model_concurrency.py b/tests/test_per_model_concurrency.py
new file mode 100644
index 0000000..7777777
--- /dev/null
+++ b/tests/test_per_model_concurrency.py
@@ -0,0 +1,117 @@
+from __future__ import annotations
+
+import argparse
+
+from omlx.cli import _parse_per_model_max_concurrent_arg
+from omlx.scheduler import Request, Scheduler
+from omlx.settings import SchedulerSettings
+
+
+def test_parse_per_model_max_concurrent_flag() -> None:
+    parsed = _parse_per_model_max_concurrent_arg("qwen3-8b=4,granite-3b=8")
+    assert parsed == {"qwen3-8b": 4, "granite-3b": 8}
+
+
+def test_parse_per_model_max_concurrent_rejects_duplicates() -> None:
+    try:
+        _parse_per_model_max_concurrent_arg("qwen3-8b=4,qwen3-8b=8")
+    except argparse.ArgumentTypeError as exc:
+        assert "duplicate model override" in str(exc)
+    else:
+        raise AssertionError("expected argparse.ArgumentTypeError")
+
+
+def test_scheduler_settings_round_trip() -> None:
+    settings = SchedulerSettings(
+        max_concurrent_requests=2,
+        max_completion_batch_size=1,
+        per_model_max_concurrent={"qwen3-8b": 4, "granite-3b": 8},
+    )
+    data = settings.to_dict()
+    restored = SchedulerSettings.from_dict(data)
+    assert restored.per_model_max_concurrent == {
+        "qwen3-8b": 4,
+        "granite-3b": 8,
+    }
+
+
+def test_scheduler_settings_apply_args() -> None:
+    args = argparse.Namespace(
+        max_concurrent_requests=None,
+        max_completion_batch_size=None,
+        per_model_max_concurrent="qwen3-8b=4,granite-3b=8",
+    )
+    settings = SchedulerSettings()
+    settings.apply_args(args)
+    assert settings.per_model_max_concurrent == {
+        "qwen3-8b": 4,
+        "granite-3b": 8,
+    }
+
+
+def test_scheduler_respects_per_model_cap() -> None:
+    settings = SchedulerSettings(
+        max_concurrent_requests=4,
+        per_model_max_concurrent={"qwen3-8b": 1},
+    )
+    scheduler = Scheduler(settings)
+    scheduler.running = [Request(model="qwen3-8b")]
+    scheduler.waiting = [
+        Request(model="qwen3-8b"),
+        Request(model="granite-3b"),
+    ]
+
+    scheduler._schedule_waiting()
+
+    assert [req.model for req in scheduler.running] == [
+        "qwen3-8b",
+        "granite-3b",
+    ]
+    assert [req.model for req in scheduler.waiting] == ["qwen3-8b"]
+
+
+def test_scheduler_falls_back_to_global_cap() -> None:
+    settings = SchedulerSettings(max_concurrent_requests=1)
+    scheduler = Scheduler(settings)
+    scheduler.running = [Request(model="qwen3-8b")]
+    scheduler.waiting = [Request(model="granite-3b")]
+
+    scheduler._schedule_waiting()
+
+    assert [req.model for req in scheduler.running] == ["qwen3-8b"]
+    assert [req.model for req in scheduler.waiting] == ["granite-3b"]
