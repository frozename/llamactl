     command_buffer->addCompletedHandler(
         [s, buffers = std::move(buffers)](MTL::CommandBuffer* cbuf) {
+          scheduler::release_stream_slot(s);
           // Stash any error FIRST so a thread woken by
           // notify_task_completion is guaranteed to observe it on the
           // next throw_if_stream_error waitpoint. Reversing this order
@@ -98,6 +120,7 @@
           check_error(s, cbuf);
           scheduler::notify_task_completion(s);
         });
+    scheduler::acquire_stream_slot(s, read_inflight_limit(), read_backpressure_timeout());
     encoder.commit();
   } else {
     command_buffer->addCompletedHandler(
@@ -113,8 +136,11 @@
   auto& encoder = metal::get_command_encoder(s);
   auto* cb = encoder.get_command_buffer();
   encoder.end_encoding();
-  cb->addCompletedHandler(
-      [s](MTL::CommandBuffer* cbuf) { check_error(s, cbuf); });
+  cb->addCompletedHandler([s](MTL::CommandBuffer* cbuf) {
+    scheduler::release_stream_slot(s);
+    check_error(s, cbuf);
+  });
+  scheduler::acquire_stream_slot(s, read_inflight_limit(), read_backpressure_timeout());
   encoder.commit();
 }

--- a/dev/null
+++ b/mlx/tests/test_metal_backpressure.cpp
@@ -0,0 +1,109 @@
+// Copyright © 2023 Apple Inc.
+//
+// Per-stream in-flight command-buffer gate — unit tests.
+// Exercises acquire_stream_slot / release_stream_slot without a Metal device.
+// Stream objects use out-of-range test indices that cannot collide with real GPU
+// streams, and no GPU kernels are executed.
+//
+// Run: ./mlx_tests "[backpressure]"
+
+#include <atomic>
+#include <chrono>
+#include <limits>
+#include <stdexcept>
+#include <thread>
+
+#include <catch2/catch_test_macros.hpp>
+
+#include "mlx/scheduler.h"
+
+using namespace mlx::core;
+using namespace mlx::core::scheduler;
+using namespace std::chrono_literals;
+
+// Construct a test-only Stream that cannot collide with real streams.
+static Stream make_test_stream(int idx) {
+  return Stream{idx, Device::cpu};
+}
+
+// ─── Test A ───────────────────────────────────────────────────────────────────
+TEST_CASE("stream gate blocks at limit", "[backpressure]") {
+  auto s = make_test_stream(99001);
+
+  // Thread A acquires the single slot immediately (inflight becomes 1).
+  acquire_stream_slot(s, /*limit=*/1, /*timeout_secs=*/5);
+
+  // Thread B tries to acquire — must NOT return within 50 ms.
+  std::atomic<bool> b_returned{false};
+  std::thread b([&s, &b_returned] {
+    acquire_stream_slot(s, /*limit=*/1, /*timeout_secs=*/5);
+    b_returned.store(true, std::memory_order_release);
+    release_stream_slot(s);
+  });
+
+  std::this_thread::sleep_for(50ms);
+  CHECK(!b_returned.load(std::memory_order_acquire));
+
+  // Release A's slot — B must unblock and complete within 200 ms.
+  release_stream_slot(s);
+  auto deadline = std::chrono::steady_clock::now() + 200ms;
+  while (!b_returned.load(std::memory_order_acquire) &&
+         std::chrono::steady_clock::now() < deadline) {
+    std::this_thread::sleep_for(5ms);
+  }
+  CHECK(b_returned.load(std::memory_order_acquire));
+  b.join();
+}
+
+// ─── Test B ───────────────────────────────────────────────────────────────────
+TEST_CASE("stream gate fast path throughput", "[backpressure]") {
+  auto s = make_test_stream(99002);
+  constexpr int kIter = 10000;
+
+  auto t0 = std::chrono::steady_clock::now();
+  for (int i = 0; i < kIter; ++i) {
+    acquire_stream_slot(s, std::numeric_limits<int>::max());
+    release_stream_slot(s);
+  }
+  auto elapsed_ms =
+      std::chrono::duration_cast<std::chrono::milliseconds>(
+          std::chrono::steady_clock::now() - t0)
+          .count();
+
+  // 10 000 lock/unlock cycles must complete in < 5 ms on any M-series Mac.
+  // Guards the hot-path regression constraint for single-model workloads.
+  CHECK(elapsed_ms < 5);
+}
+
+// ─── Test C ───────────────────────────────────────────────────────────────────
+TEST_CASE("stream gate timeout injects stream error", "[backpressure]") {
+  auto s = make_test_stream(99003);
+
+  // Thread A acquires the single slot and holds it for the duration of the test.
+  acquire_stream_slot(s, /*limit=*/1, /*timeout_secs=*/30);
+
+  // Thread B tries to acquire with a 1-second timeout — must time out.
+  // On timeout the implementation increments the counter and injects an error,
+  // mirroring the production path where encoder.commit() still runs after a
+  // timed-out acquire. Thread B therefore releases its (timeout-incremented)
+  // slot, keeping the counter balanced for test teardown.
+  std::thread b([&s] {
+    acquire_stream_slot(s, /*limit=*/1, /*timeout_secs=*/1);
+    release_stream_slot(s); // balance the counter increment on timeout
+  });
+  b.join(); // waits ~1 s for the timeout to fire
+
+  // The timeout must have injected a "[MLX] backpressure timeout" error.
+  bool threw = false;
+  try {
+    throw_if_stream_error(s);
+  } catch (const std::runtime_error& e) {
+    threw = true;
+    std::string msg = e.what();
+    CHECK(msg.find("backpressure timeout") != std::string::npos);
+  }
+  CHECK(threw);
+
+  // Cleanup: release A's slot.
+  release_stream_slot(s);
+}
