--- a/mlx/scheduler.h
+++ b/mlx/scheduler.h
@@ -3,6 +3,8 @@
 #pragma once
 
 #include <atomic>
+#include <chrono>
+#include <limits>
 #include <future>
 #include <queue>
 #include <shared_mutex>
@@ -174,8 +176,51 @@
       stream_errors_.clear();
     }
     any_stream_error_.store(false, std::memory_order_release);
+  }
+  // Acquire a slot on stream `s` before committing a Metal command buffer.
+  // Blocks until `stream_inflight_[s.index] < limit`. When limit ==
+  // INT_MAX the wait is skipped — one mutex lock per commit on the fast
+  // path. On timeout injects a backpressure error via notify_stream_error
+  // so the caller's next throw_if_stream_error unwinds it.
+  //
+  // `inflight_mtx_` is intentionally separate from `error_mtx_`: the
+  // timeout branch calls notify_stream_error (which locks error_mtx_)
+  // while inflight_mtx_ is still held — using one mutex would deadlock.
+  void acquire_stream_slot(
+      const Stream& s, int limit, int timeout_secs = 30) {
+    std::unique_lock<std::mutex> lk(inflight_mtx_);
+    if (limit == std::numeric_limits<int>::max()) {
+      stream_inflight_[s.index]++;
+      return;
+    }
+    bool ok = inflight_cv_.wait_for(
+        lk,
+        std::chrono::seconds(timeout_secs),
+        [&] { return stream_inflight_[s.index] < limit; });
+    stream_inflight_[s.index]++;
+    if (!ok) {
+      lk.unlock();
+      notify_stream_error(
+          s,
+          std::make_exception_ptr(std::runtime_error(
+              "[MLX] backpressure timeout: stream " +
+              std::to_string(s.index) + " held >= " +
+              std::to_string(limit) +
+              " in-flight command buffers for " +
+              std::to_string(timeout_secs) + "s")));
+    }
   }
 
+  void release_stream_slot(const Stream& s) {
+    {
+      std::lock_guard<std::mutex> lk(inflight_mtx_);
+      auto it = stream_inflight_.find(s.index);
+      if (it != stream_inflight_.end() && it->second > 0)
+        it->second--;
+    }
+    inflight_cv_.notify_all();
+  }
+
   void wait_for_one() {
     std::unique_lock<std::mutex> lk(mtx);
     int n_tasks_old = n_active_tasks();
@@ -200,6 +245,9 @@
   // Lets `throw_if_stream_error` short-circuit on the common no-error path
   // without touching the mutex.
   std::atomic<bool> any_stream_error_{false};
+  std::unordered_map<int, int> stream_inflight_;
+  std::condition_variable      inflight_cv_;
+  std::mutex                   inflight_mtx_;
 };
 
 MLX_API Scheduler& scheduler();
@@ -243,4 +291,12 @@
   scheduler().wait_for_one();
 }
 
+inline void acquire_stream_slot(
+    const Stream& s, int limit, int timeout_secs = 30) {
+  scheduler().acquire_stream_slot(s, limit, timeout_secs);
+}
+inline void release_stream_slot(const Stream& s) {
+  scheduler().release_stream_slot(s);
+}
+
 } // namespace mlx::core::scheduler

