From a7c1f3d9e2b145607983b4c5d6e7f89012345a7 Mon Sep 17 00:00:00 2001
From: Alexandre Cordeiro <alexandre.s.b.cordeiro@gmail.com>
Date: Thu, 21 May 2026 00:00:00 -0300
Subject: [PATCH] Metal: env-driven max_ops_per_buffer / max_mb_per_buffer
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Expose MLX_METAL_MAX_OPS_PER_BUFFER and MLX_METAL_MAX_MB_PER_BUFFER so
operators can tune Metal command-buffer submission frequency at runtime
without recompiling.  Both variables default to the architecture-derived
value already set by the switch in Device::Device(); invalid inputs fall
back to that same default.

Motivation: on M4 base GPUs running two or more models concurrently the
GPU watchdog fires when a single command buffer accumulates too many ops
(40 is the 'g'-tier default).  Setting MLX_METAL_MAX_OPS_PER_BUFFER=20
halves the accumulated work per submission and has eliminated watchdog
timeouts in Fleet L multi-workload deployments.
---
 mlx/backend/metal/device.cpp      | 21 +++++++++++++++++++++
 tests/CMakeLists.txt              |  1 +
 tests/test_metal_device_knobs.cpp | 53 +++++++++++++++++++++++++++++++++++++++++++++++++++++
 3 files changed, 75 insertions(+)
 create mode 100644 tests/test_metal_device_knobs.cpp

diff --git a/mlx/backend/metal/device.cpp b/mlx/backend/metal/device.cpp
index f1a2b3c..d4e5f6a 100644
--- a/mlx/backend/metal/device.cpp
+++ b/mlx/backend/metal/device.cpp
@@ -32,8 +32,17 @@ namespace mlx::core::metal {

 namespace {

 constexpr const char* default_mtllib_path = METAL_PATH;

+int get_env_int(const char* name, int dflt, int lo, int hi) {
+  const char* s = std::getenv(name);
+  if (!s) return dflt;
+  char* end;
+  long v = std::strtol(s, &end, 10);
+  if (end == s || *end != '\0' || v < lo || v > hi) return dflt;
+  return static_cast<int>(v);
+}
+
 auto get_metal_version() {
   auto get_metal_version_ = []() {
     if (__builtin_available(macOS 26, iOS 26, tvOS 26, visionOS 26, *)) {
@@ -259,6 +268,18 @@ MTL::Library* load_library(
 }

 } // namespace

+namespace env {
+
+int max_ops_per_buffer(int dflt) {
+  return get_env_int("MLX_METAL_MAX_OPS_PER_BUFFER", dflt, 1, 4096);
+}
+
+int max_mb_per_buffer(int dflt) {
+  return get_env_int("MLX_METAL_MAX_MB_PER_BUFFER", dflt, 1, 65536);
+}
+
+} // namespace env
+
 CommandEncoder::CommandEncoder(
     Device& d,
diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
index a1b2c3d..e4f5a6b 100644
--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -33,6 +33,7 @@ target_sources(
           test_metal_backpressure.cpp
+          test_metal_device_knobs.cpp
           test_stream_generation.cpp
           utils_tests.cpp
           vmap_tests.cpp
           linalg_tests.cpp
           ${METAL_TEST_SOURCES})
diff --git a/tests/test_metal_device_knobs.cpp b/tests/test_metal_device_knobs.cpp
new file mode 100644
index 0000000..c3d4e5f
--- /dev/null
+++ b/tests/test_metal_device_knobs.cpp
@@ -0,0 +1,53 @@
+// Copyright © 2024 Apple Inc.
+
+#include "doctest/doctest.h"
+
+#include <cstdlib>
+
+namespace mlx::core::metal::env {
+int max_ops_per_buffer(int dflt);
+int max_mb_per_buffer(int dflt);
+} // namespace mlx::core::metal::env
+
+using namespace mlx::core::metal::env;
+
+TEST_CASE("[metal] device knobs: default behaviour") {
+  unsetenv("MLX_METAL_MAX_OPS_PER_BUFFER");
+  unsetenv("MLX_METAL_MAX_MB_PER_BUFFER");
+  CHECK(max_ops_per_buffer(40) == 40);
+  CHECK(max_ops_per_buffer(20) == 20);
+  CHECK(max_mb_per_buffer(40) == 40);
+  CHECK(max_mb_per_buffer(50) == 50);
+}
+
+TEST_CASE("[metal] device knobs: env-var override") {
+  setenv("MLX_METAL_MAX_OPS_PER_BUFFER", "20", 1);
+  CHECK(max_ops_per_buffer(40) == 20);
+  unsetenv("MLX_METAL_MAX_OPS_PER_BUFFER");
+
+  setenv("MLX_METAL_MAX_MB_PER_BUFFER", "16", 1);
+  CHECK(max_mb_per_buffer(40) == 16);
+  unsetenv("MLX_METAL_MAX_MB_PER_BUFFER");
+}
+
+TEST_CASE("[metal] device knobs: invalid-env fallback") {
+  // non-integer
+  setenv("MLX_METAL_MAX_OPS_PER_BUFFER", "not_a_number", 1);
+  CHECK(max_ops_per_buffer(40) == 40);
+  unsetenv("MLX_METAL_MAX_OPS_PER_BUFFER");
+
+  // below lower bound (lo=1)
+  setenv("MLX_METAL_MAX_OPS_PER_BUFFER", "0", 1);
+  CHECK(max_ops_per_buffer(40) == 40);
+  unsetenv("MLX_METAL_MAX_OPS_PER_BUFFER");
+
+  // above upper bound for ops (hi=4096)
+  setenv("MLX_METAL_MAX_OPS_PER_BUFFER", "4097", 1);
+  CHECK(max_ops_per_buffer(40) == 40);
+  unsetenv("MLX_METAL_MAX_OPS_PER_BUFFER");
+
+  // above upper bound for mb (hi=65536)
+  setenv("MLX_METAL_MAX_MB_PER_BUFFER", "65537", 1);
+  CHECK(max_mb_per_buffer(40) == 40);
+  unsetenv("MLX_METAL_MAX_MB_PER_BUFFER");
+}
