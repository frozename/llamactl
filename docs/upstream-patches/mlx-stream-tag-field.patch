From 982ef62df8822f70dce7869dfe0e65c76cfe3741 Mon Sep 17 00:00:00 2001
Subject: [PATCH] stream: add optional tag field to Stream struct

Adds `std::optional<std::string> tag = std::nullopt;` to the `Stream`
struct. Higher layers (oMLX, mlx-lm) can stamp a stream with a model
name; the per-stream CommandQueue (B.2) and ResidencySet (B.3) patches
use this to key per-model GPU resources without a separate side-table.

No changes to stream.cpp — `std::optional` zero-initialises to
`std::nullopt` and the default copy/move semantics are correct.
The field is advisory at this stage; it is consumed only by the B.2/B.3
follow-up patches.

Backward-compatible: `tag` defaults to `std::nullopt`, so all existing
call sites compile unchanged. The defaulted `operator==` now includes
`tag` in comparison; in practice this is a no-op because untagged
streams (the common case) all carry `std::nullopt`.

Requires: mlx-stream-generation-counter.patch (A.1)
---
 mlx/stream.h              |  3 +++
 tests/CMakeLists.txt      |  1 +
 tests/test_stream_tag.cpp | 21 +++++++++++++++++++++
 3 files changed, 25 insertions(+)
 create mode 100644 tests/test_stream_tag.cpp

diff --git a/mlx/stream.h b/mlx/stream.h
index 0000000..0000000 100644
--- a/mlx/stream.h
+++ b/mlx/stream.h
@@ -3,6 +3,8 @@
 #pragma once

 #include <atomic>
+#include <optional>
+#include <string>
 #include <cstdint>
 #include <vector>

@@ -19,6 +21,7 @@
   // stream reuses the same index, the stale generation lets the scheduler
   // distinguish the old handler's error from a real error on the new stream.
   uint64_t generation{0};
+  std::optional<std::string> tag = std::nullopt;
   explicit Stream(int index, Device device) : index(index), device(device) {}

   // TODO: Use default three-way comparison when it gets supported in XCode.
diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
index 0000000..0000000 100644
--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -33,6 +33,7 @@
           scheduler_tests.cpp
           test_metal_backpressure.cpp
           test_stream_generation.cpp
+          test_stream_tag.cpp
           utils_tests.cpp
           vmap_tests.cpp
           linalg_tests.cpp
diff --git a/tests/test_stream_tag.cpp b/tests/test_stream_tag.cpp
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/tests/test_stream_tag.cpp
@@ -0,0 +1,21 @@
+// Copyright © 2026 Apple Inc.
+
+#include <doctest/doctest.h>
+
+#include "mlx/stream.h"
+
+using namespace mlx::core;
+
+TEST_CASE("A fresh stream has an empty tag") {
+  Stream s = new_stream(Device::cpu);
+  CHECK_FALSE(s.tag.has_value());
+}
+
+TEST_CASE("Assigning a tag round-trips through stream copy") {
+  Stream s = new_stream(Device::cpu);
+  s.tag = "my-stream";
+  Stream s2 = s;
+  REQUIRE(s2.tag.has_value());
+  CHECK(s2.tag.value() == "my-stream");
+}
+
