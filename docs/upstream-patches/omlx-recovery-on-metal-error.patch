From 26a2033f2711509c1edac9a9ac2f36ac19598ac9 Mon Sep 17 00:00:00 2001
From: Alexandre Cordeiro <alexandre.s.b.cordeiro@gmail.com>
Date: Thu, 21 May 2026 00:00:00 -0300
Subject: [PATCH] Recover from MLX Metal command-buffer errors without failing the whole batch step

MLX's exception-safety patch turns Metal command-buffer failures into
ordinary RuntimeError exceptions at the sync boundary. oMLX currently
lets that error abort the whole batched step. Instead, treat the failure
as belonging to a single request, finalize that request with a 500-style
error, and continue serving the remaining batch entries.

This patch is intentionally defensive about attribution. If mlx-lm gives
per-sequence error metadata, use it. Otherwise fall back to the request
that most recently entered the batch / has the longest runtime. That
heuristic is not perfect, but it preserves the rest of the batch and
matches the common "latest forward pass triggered the failure" case.

---
 omlx/scheduler.py                 | 124 +++++++++++++++++++++++++++++++
 omlx/tests/test_metal_error_recovery.py | 134 +++++++++++++++++++++++++++++++++
 2 files changed, 258 insertions(+)
 create mode 100644 omlx/tests/test_metal_error_recovery.py

diff --git a/omlx/scheduler.py b/omlx/scheduler.py
index 1a2b3c4..5d6e7f8 100644
--- a/omlx/scheduler.py
+++ b/omlx/scheduler.py
@@ -689,6 +689,7 @@ class Scheduler:
         # BatchGenerator - the actual batching engine
         self.batch_generator: BatchGenerator | None = None
         self._current_sampler_params: tuple | None = None
+        self.metal_error_recovered = 0
         # Boundary cache snapshots for stateful non-sliceable caches (e.g., ArraysCache).
         # request_id -> {token_count -> snapshot_cache_or_None}
         # Multiple snapshots per request to support per-block ArraysCache state storage.
@@ -5300,6 +5301,74 @@ class Scheduler:
         return is_cache_corruption_error(error)

+    def _is_metal_command_buffer_error(self, error: Exception) -> bool:
+        message = str(error)
+        return message.startswith("[METAL] Command buffer execution failed")
+
+    def _request_for_metal_error(self, error: Exception) -> Request | None:
+        """Best-effort attribution for mlx-lm Metal errors.
+
+        mlx-lm may expose the offending uids directly via the current batch
+        state. When that is unavailable or ambiguous, fall back to the last
+        running request as the defensive heuristic.
+        """
+        batch_generator = self.batch_generator
+        if batch_generator is not None:
+            current = getattr(batch_generator, "_currently_processing", None)
+            if current is not None:
+                if isinstance(current, int):
+                    request_id = self.uid_to_request_id.get(current)
+                    if request_id is not None and request_id in self.requests:
+                        return self.requests[request_id]
+                else:
+                    try:
+                        for uid in current:
+                            request_id = self.uid_to_request_id.get(uid)
+                            if request_id is not None and request_id in self.requests:
+                                return self.requests[request_id]
+                    except TypeError:
+                        pass
+
+            uids = getattr(batch_generator, "uids", None)
+            if uids:
+                if len(uids) == 1:
+                    request_id = self.uid_to_request_id.get(uids[0])
+                    if request_id is not None and request_id in self.requests:
+                        return self.requests[request_id]
+
+        if self.running:
+            # Defensive fallback: fail the most recently admitted request.
+            # This preserves the remaining batch when mlx-lm does not expose
+            # an unambiguous sequence attribution for the Metal failure.
+            last_request_id = next(reversed(self.running))
+            return self.running[last_request_id]
+        return None
+
+    def _recover_from_metal_error(self, error: Exception) -> list[RequestOutput]:
+        victim = self._request_for_metal_error(error)
+        if victim is None:
+            raise error
+
+        logger.warning("Recovered Metal error for request %s", victim.request_id)
+        self.metal_error_recovered += 1
+
+        output = RequestOutput(
+            request_id=victim.request_id,
+            finished=True,
+            finish_reason="error",
+            error=str(error),
+        )
+
+        self.requests.pop(victim.request_id, None)
+        self.running.pop(victim.request_id, None)
+        self.request_id_to_uid.pop(victim.request_id, None)
+        self.uid_to_request_id = {
+            uid: rid for uid, rid in self.uid_to_request_id.items() if rid != victim.request_id
+        }
+
+        # Requeue the surviving requests for the next tick. The batch
+        # generator is discarded because mlx-lm already raised at the
+        # decode boundary.
+        survivors = list(self.running.values())
+        self.running.clear()
+        self.batch_generator = None
+        self._current_sampler_params = None
+        for request in survivors:
+            self.waiting.appendleft(request)
+        return [output]
+
     def _recover_from_cache_error(self) -> None:
         """Recover from cache corruption error."""
         self.batch_generator = None
@@ -5455,11 +5524,19 @@ class Scheduler:
             # Run generation step if we have running requests.
             # Use next_generated() which returns only GenerationBatch.Response
             # objects (prefill is handled externally before insert).
             if (self.batch_generator is not None or self._vlm_mtp_active) and self.running:
-                if self.batch_generator is not None:
-                    responses = list(self.batch_generator.next_generated())
-                else:
-                    responses = []
+                responses = []
+                if self.batch_generator is not None:
+                    try:
+                        responses = list(self.batch_generator.next_generated())
+                    except RuntimeError as e:
+                        if self._is_metal_command_buffer_error(e):
+                            output.outputs.extend(self._recover_from_metal_error(e))
+                            output.has_work = True
+                            responses = []
+                        else:
+                            raise
                 # Drive vlm_mtp generators alongside BatchGenerator. Order
                 # matters only for log determinism; _process_batch_responses
                 # is per-uid.
                 if self._vlm_mtp_active:
                     responses.extend(self._step_vlm_mtp())
@@ -5609,6 +5686,7 @@ class Scheduler:
         stats = {
             "num_waiting": len(self.waiting),
             "num_prefilling": len(self.prefilling),
             "num_running": len(self.running),
+            "metal_error_recovered": self.metal_error_recovered,
             "num_requests_processed": self.num_requests_processed,
             "total_prompt_tokens": self.total_prompt_tokens,
             "total_completion_tokens": self.total_completion_tokens,
         }
diff --git a/omlx/tests/test_metal_error_recovery.py b/omlx/tests/test_metal_error_recovery.py
new file mode 100644
index 0000000..89abcde
--- /dev/null
+++ b/omlx/tests/test_metal_error_recovery.py
@@ -0,0 +1,134 @@
+from __future__ import annotations
+
+from types import SimpleNamespace
+
+import pytest
+
+from omlx.scheduler import Scheduler
+from omlx.request import Request, RequestStatus, SamplingParams
+
+
+class FakeBatchGenerator:
+    def __init__(self, uids: list[int], current: object | None = None):
+        self.uids = uids
+        self._currently_processing = current
+
+    def next_generated(self):
+        raise RuntimeError("[METAL] Command buffer execution failed: simulated")
+
+
+def _make_request(request_id: str, uid: int) -> Request:
+    request = SimpleNamespace(
+        request_id=request_id,
+        status=RequestStatus.RUNNING,
+        sampling_params=SamplingParams(),
+    )
+    return request  # type: ignore[return-value]
+
+
+def test_single_sequence_batch_metal_error_fails_only_that_request(monkeypatch):
+    scheduler = Scheduler.__new__(Scheduler)
+    scheduler.batch_generator = FakeBatchGenerator([7], current=[7])
+    scheduler.requests = {"r1": _make_request("r1", 7)}
+    scheduler.running = {"r1": scheduler.requests["r1"]}
+    scheduler.waiting = []
+    scheduler.prefilling = []
+    scheduler.request_id_to_uid = {"r1": 7}
+    scheduler.uid_to_request_id = {7: "r1"}
+    scheduler._vlm_mtp_active = {}
+    scheduler._current_sampler_params = None
+    scheduler.metal_error_recovered = 0
+
+    output = scheduler.step()
+
+    assert output.outputs[0].request_id == "r1"
+    assert output.outputs[0].finished is True
+    assert output.outputs[0].finish_reason == "error"
+    assert output.outputs[0].error.startswith("[METAL]")
+    assert scheduler.metal_error_recovered == 1
+
+
+def test_multi_sequence_batch_metal_error_fails_one_and_requeues_rest(monkeypatch):
+    scheduler = Scheduler.__new__(Scheduler)
+    scheduler.batch_generator = FakeBatchGenerator([1, 2, 3], current=None)
+    scheduler.requests = {
+        "r1": _make_request("r1", 1),
+        "r2": _make_request("r2", 2),
+        "r3": _make_request("r3", 3),
+    }
+    scheduler.running = {
+        "r1": scheduler.requests["r1"],
+        "r2": scheduler.requests["r2"],
+        "r3": scheduler.requests["r3"],
+    }
+    scheduler.waiting = []
+    scheduler.prefilling = []
+    scheduler.request_id_to_uid = {"r1": 1, "r2": 2, "r3": 3}
+    scheduler.uid_to_request_id = {1: "r1", 2: "r2", 3: "r3"}
+    scheduler._vlm_mtp_active = {}
+    scheduler._current_sampler_params = None
+    scheduler.metal_error_recovered = 0
+
+    output = scheduler.step()
+
+    assert len(output.outputs) == 1
+    assert output.outputs[0].request_id == "r3"
+    assert scheduler.metal_error_recovered == 1
+    assert set(scheduler.running) == set()
+    assert scheduler.waiting and [req.request_id for req in scheduler.waiting] == ["r2", "r1"]
