diff --git a/tests/test_metal_per_stream_queue.cpp b/tests/test_metal_per_stream_queue.cpp
new file mode 100644
index 00000000..4f2d8c1a
--- /dev/null
+++ b/tests/test_metal_per_stream_queue.cpp
@@ -0,0 +1,104 @@
+// Copyright © 2024 Apple Inc.
+//
+// Unit tests for per-stream MTL::CommandQueue allocation (PR #NNNN).
+// Requires a real Metal device; compiled only when MLX_BUILD_METAL is set.
+//
+// Coverage:
+//   1. A fresh stream returns a non-null per-stream queue; repeated calls
+//      return the same underlying queue object (idempotency).
+//   2. Two distinct streams have distinct (non-aliasing) queues.
+//   3. release_stream_queue removes the map entry; subsequent allocation
+//      for the same index succeeds (non-null result).
+//   4. Safety-cap fallback: once kMaxStreamQueues entries exist, a further
+//      call returns the device-global queue (non-null, differs from per-
+//      stream entries).
+
+#ifdef MLX_BUILD_METAL
+
+#include <doctest/doctest.h>
+
+#include "mlx/backend/metal/device.h"
+#include "mlx/mlx.h"
+
+using namespace mlx::core;
+using namespace mlx::core::metal;
+
+// ---------------------------------------------------------------------------
+// Test 1: fresh stream returns a valid, stable queue
+// ---------------------------------------------------------------------------
+TEST_CASE("[metal] per-stream queue: fresh stream returns non-null queue") {
+  auto s = new_stream(Device::gpu);
+  auto& dev = device(Device::gpu);
+
+  auto q0 = dev.queue_for_stream(s.index);
+  REQUIRE(q0.get() != nullptr);
+
+  // Idempotency: a second call must return the same underlying queue object.
+  auto q1 = dev.queue_for_stream(s.index);
+  CHECK(q0.get() == q1.get());
+
+  synchronize(s);
+}
+
+// ---------------------------------------------------------------------------
+// Test 2: two distinct streams have distinct queues
+// ---------------------------------------------------------------------------
+TEST_CASE("[metal] per-stream queue: two streams have distinct queues") {
+  auto s0 = new_stream(Device::gpu);
+  auto s1 = new_stream(Device::gpu);
+  auto& dev = device(Device::gpu);
+
+  auto q0 = dev.queue_for_stream(s0.index);
+  auto q1 = dev.queue_for_stream(s1.index);
+
+  REQUIRE(q0.get() != nullptr);
+  REQUIRE(q1.get() != nullptr);
+  // Core invariant: independent streams must have independent queues so
+  // their command buffers can be scheduled independently by the Metal driver.
+  CHECK(q0.get() != q1.get());
+
+  synchronize(s0);
+  synchronize(s1);
+}
+
+// ---------------------------------------------------------------------------
+// Test 3: release_stream_queue removes the map entry
+// ---------------------------------------------------------------------------
+TEST_CASE("[metal] per-stream queue: release_stream_queue clears map entry") {
+  auto& dev = device(Device::gpu);
+
+  // Use a synthetic high-index to avoid colliding with any live stream.
+  const int kSyntheticIndex = 99901;
+  auto q_before = dev.queue_for_stream(kSyntheticIndex);
+  REQUIRE(q_before.get() != nullptr);
+
+  dev.release_stream_queue(kSyntheticIndex);
+
+  // After release, a new call must allocate a fresh (valid) queue.
+  // We cannot guarantee a different pointer value (the OS may reuse the
+  // same address), but the result must be non-null.
+  auto q_after = dev.queue_for_stream(kSyntheticIndex);
+  CHECK(q_after.get() != nullptr);
+
+  // Cleanup: remove the re-allocated synthetic entry.
+  dev.release_stream_queue(kSyntheticIndex);
+}
+
+// ---------------------------------------------------------------------------
+// Test 4: safety-cap fallback returns the device-global queue
+// ---------------------------------------------------------------------------
+TEST_CASE("[metal] per-stream queue: safety cap falls back to device-global queue") {
+  auto& dev = device(Device::gpu);
+  const int cap = Device::kMaxStreamQueues;
+
+  // Warm the per-stream map to exactly kMaxStreamQueues entries using
+  // synthetic indices that cannot collide with live stream indices.
+  const int kBase = 20000;
+  for (int i = kBase; i < kBase + cap; ++i) {
+    REQUIRE(dev.queue_for_stream(i).get() != nullptr);
+  }
+
+  // One index beyond the cap must still return a non-null queue (fallback).
+  auto q_overflow = dev.queue_for_stream(kBase + cap);
+  CHECK(q_overflow.get() != nullptr);
+
+  // The fallback queue is the device-global `queue_`, which differs from
+  // any per-stream entry.  Verify via inequality with a known per-stream ptr.
+  auto q_first = dev.queue_for_stream(kBase);
+  CHECK(q_overflow.get() != q_first.get());
+
+  // Cleanup: release all synthetic entries.  release_stream_queue is a
+  // no-op for the overflow index (which was never inserted into the map).
+  for (int i = kBase; i <= kBase + cap; ++i) {
+    dev.release_stream_queue(i);
+  }
+}
+
+#endif // MLX_BUILD_METAL
