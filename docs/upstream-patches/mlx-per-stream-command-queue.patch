diff --git a/mlx/backend/metal/device.cpp b/mlx/backend/metal/device.cpp
index 2b4f9c7e..6a8c1d02 100644
--- a/mlx/backend/metal/device.cpp
+++ b/mlx/backend/metal/device.cpp
@@ -1,6 +1,7 @@
 // Copyright © 2023-2024 Apple Inc.

 #include <algorithm>
+#include <mutex>
 #include <numeric>
 #include <sstream>

@@ -265,10 +266,78 @@ Device& device(mlx::core::Device d) {
   return metal_device;
 }

+NS::SharedPtr<MTL::CommandQueue> Device::queue_for_stream(int stream_index) {
+  std::lock_guard<std::mutex> lk(stream_queues_mtx_);
+  auto it = stream_queues_.find(stream_index);
+  if (it != stream_queues_.end()) {
+    // Common path: return a copy of the existing SharedPtr (increments
+    // refcount, no allocation).
+    return it->second;
+  }
+  if (static_cast<int>(stream_queues_.size()) >= kMaxStreamQueues) {
+    // Safety cap: fall back to the device-global queue and emit a one-time
+    // warning so operators know they have hit the allocation limit.
+    static std::once_flag warn_once;
+    std::call_once(warn_once, [] {
+      // NOLINTNEXTLINE(cppcoreguidelines-pro-type-vararg)
+      fprintf(
+          stderr,
+          "[MLX] Warning: per-stream MTL::CommandQueue cap (%d) reached. "
+          "Subsequent new streams will share the device-global command queue "
+          "and lose per-stream GPU scheduling isolation. "
+          "Metal's per-process queue limit is typically ~256; consider "
+          "reducing the number of concurrent MLX streams to stay within "
+          "the cap.\n",
+          Device::kMaxStreamQueues);
+    });
+    return queue_;
+  }
+  // First use for this stream index: allocate a dedicated queue.
+  // newCommandQueue() is relatively lightweight — it allocates a kernel-
+  // side slot but performs no GPU work until the first command buffer is
+  // committed.  NS::TransferPtr takes ownership of the returned +1 object.
+  auto& entry = stream_queues_[stream_index];
+  entry = NS::TransferPtr(device_->newCommandQueue());
+  return entry;
+}
+
+void Device::release_stream_queue(int stream_index) {
+  std::lock_guard<std::mutex> lk(stream_queues_mtx_);
+  stream_queues_.erase(stream_index);
+  // Note: if the stream exceeded kMaxStreamQueues it was using queue_
+  // directly — no entry exists in stream_queues_, so erase is a no-op.
+}
+
+void Device::release_all_stream_queues() {
+  std::lock_guard<std::mutex> lk(stream_queues_mtx_);
+  stream_queues_.clear();
+  // queue_ (device-global fallback) is NOT cleared here.  It lives for the
+  // Device's lifetime and is released by its SharedPtr destructor.
+}
+
 // CommandEncoder implementation

-CommandEncoder::CommandEncoder(Device& d, int stream_index, MTL::ResidencySet* rs)
-    : active_(false), queue_(d.queue_), n_blit_encoders_(0), n_compute_encoders_(0) {
-  command_buffer_ = NS::RetainPtr(queue_->commandBuffer());
+CommandEncoder::CommandEncoder(
+    Device& d,
+    int stream_index,
+    MTL::ResidencySet* rs)
+    : active_(false),
+      // Capture shared ownership of the per-stream queue so this encoder's
+      // in-flight command buffers can complete even after stream teardown.
+      stream_queue_(d.queue_for_stream(stream_index)),
+      n_blit_encoders_(0),
+      n_compute_encoders_(0) {
+  // commandBuffer() returns an autoreleased object; NS::RetainPtr bumps the
+  // refcount so command_buffer_ holds a strong reference.
+  command_buffer_ = NS::RetainPtr(stream_queue_->commandBuffer());
   if (rs != nullptr) {
     command_buffer_->useResidencySet(rs);
   }
@@ -318,10 +387,12 @@ CommandEncoder::~CommandEncoder() {}

 // Commit the current command buffer and allocate a fresh one from the
 // per-stream queue so subsequent operations on this stream are independent.
 void CommandEncoder::commit() {
+  // Draw the next buffer from stream_queue_ (not the device-global queue_)
+  // so all buffers for this stream stay on the same dedicated queue.
   command_buffer_->commit();
-  command_buffer_ = NS::RetainPtr(queue_->commandBuffer());
+  command_buffer_ = NS::RetainPtr(stream_queue_->commandBuffer());
   n_blit_encoders_ = 0;
   n_compute_encoders_ = 0;
   active_ = false;
 }
diff --git a/mlx/backend/metal/eval.cpp b/mlx/backend/metal/eval.cpp
index 1a371c3f..7b4e8d92 100644
--- a/mlx/backend/metal/eval.cpp
+++ b/mlx/backend/metal/eval.cpp
@@ -13,12 +13,19 @@ void init() {}

 void new_stream(Stream s) {
   assert(s.device == Device::gpu);
   // Defensive: if `s.index` is being reused after a prior stream was torn
   // down, drop any stale error that may have been stashed against this
   // index but never consumed. Prevents cross-stream error attribution
   // when callers create / destroy / recreate streams.
   scheduler::clear_stream_error(s);
   auto& encoders = metal::get_command_encoders();
   auto& d = metal::device(s.device);
+  // Pre-allocate the per-stream queue before constructing the CommandEncoder.
+  // The encoder's constructor calls queue_for_stream internally; doing it
+  // here first ensures the map entry exists before try_emplace runs, so the
+  // constructor hits the fast (cached) path rather than the allocation path
+  // under the mutex.  Idempotent: if the entry already exists this is a
+  // cheap SharedPtr copy that is immediately discarded.
+  d.queue_for_stream(s.index);
   encoders.try_emplace(s.index, d, s.index, d.residency_set());
 }

@@ -128,7 +135,11 @@ void synchronize(Stream s) {

 void clear_streams() {
   metal::get_command_encoders().clear();
   // Encoders are gone; drop any errors stashed against now-dead streams.
   scheduler::clear_all_stream_errors();
+  // Release per-stream command queues now that all encoders have been
+  // destroyed.  Encoders hold shared ownership so any in-flight command
+  // buffers can still complete, but clearing the map here allows fresh
+  // queues to be allocated on the next new_stream call.
+  metal::device(Device::gpu).release_all_stream_queues();
 }

 } // namespace mlx::core::gpu
