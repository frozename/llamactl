{"id":"adv-040","category":"name-collision","messages":[{"role":"system","content":"You manage calendar items."},{"role":"user","content":"Put a tentative hold on Thursday from 1 to 2 PM."},{"role":"assistant","tool_calls":[{"type":"function","function":{"name":"calendar_create_hold","arguments":"{\"title\":\"Tentative hold\",\"start\":\"2026-05-21T13:00:00-03:00\",\"duration_minutes\":60}"}}]}],"tools":[{"type":"function","function":{"name":"calendar_create_event","description":"Create a scheduled calendar event","parameters":{"type":"object","properties":{"title":{"type":"string"},"start":{"type":"string"},"duration_minutes":{"type":"integer"}},"required":["title","start","duration_minutes"]}}},{"type":"function","function":{"name":"calendar_create_note","description":"Create a calendar note without scheduling","parameters":{"type":"object","properties":{"title":{"type":"string"},"date":{"type":"string","format":"date"},"note":{"type":"string"}},"required":["title","date"]}}},{"type":"function","function":{"name":"calendar_create_hold","description":"Create a tentative hold on the calendar","parameters":{"type":"object","properties":{"title":{"type":"string"},"start":{"type":"string"},"duration_minutes":{"type":"integer"}},"required":["title","start","duration_minutes"]}}}],"notes":"Tentative hold is a distinct semantic from a confirmed event."}
