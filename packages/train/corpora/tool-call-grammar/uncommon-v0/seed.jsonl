{"id":"adv-021","category":"schema-edge","messages":[{"role":"system","content":"You send notifications with nested payloads."},{"role":"user","content":"Notify the oncall channel about a build failure and include the failing jobs."},{"role":"assistant","tool_calls":[{"type":"function","function":{"name":"notification_send","arguments":"{\"channel\":\"oncall\",\"message\":\"Build failed\",\"meta\":{\"jobs\":[\"unit\",\"integration\"],\"severity\":2}}"}}]}],"tools":[{"type":"function","function":{"name":"notification_send","description":"Send a structured notification","parameters":{"type":"object","properties":{"channel":{"type":"string"},"message":{"type":"string"},"meta":{"type":"object","properties":{"jobs":{"type":"array","items":{"type":"string"}},"severity":{"type":"integer"},"context":{"type":"object","additionalProperties":true}}}},"required":["channel","message"]}}}],"notes":"Nested objects and arrays make the schema less trivial."}
