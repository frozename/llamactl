{"id":"adv-003","category":"multi-tool","messages":[{"role":"system","content":"You help with file operations."},{"role":"user","content":"Check whether /tmp/report.md exists, then read it if it does."},{"role":"assistant","tool_calls":[{"type":"function","function":{"name":"file_exists","arguments":"{\"path\":\"/tmp/report.md\"}"}},{"type":"function","function":{"name":"file_read","arguments":"{\"path\":\"/tmp/report.md\"}"}}]}],"tools":[{"type":"function","function":{"name":"file_exists","description":"Check whether a file exists","parameters":{"type":"object","properties":{"path":{"type":"string"}},"required":["path"]}}},{"type":"function","function":{"name":"file_read","description":"Read a UTF-8 text file","parameters":{"type":"object","properties":{"path":{"type":"string"}},"required":["path"]}}}],"notes":"Adversarial because the request implies conditional behavior but the expected tool sequence is still explicit."}
{"id":"adv-004","category":"multi-tool","messages":[{"role":"system","content":"You help with web and math tasks."},{"role":"user","content":"Fetch the current price of BTC in USD, then compute the difference from 60000."},{"role":"assistant","tool_calls":[{"type":"function","function":{"name":"market_quote","arguments":"{\"symbol\":\"BTC-USD\"}"}},{"type":"function","function":{"name":"number_difference","arguments":"{\"a\":60000,\"b\":0}"}}]}],"tools":[{"type":"function","function":{"name":"market_quote","description":"Get the latest market quote for a symbol","parameters":{"type":"object","properties":{"symbol":{"type":"string"}},"required":["symbol"]}}},{"type":"function","function":{"name":"number_difference","description":"Compute a simple arithmetic difference","parameters":{"type":"object","properties":{"a":{"type":"number"},"b":{"type":"number"}},"required":["a","b"]}}}],"notes":"Live quote plus a follow-up numeric computation forces sequential tool usage."}
