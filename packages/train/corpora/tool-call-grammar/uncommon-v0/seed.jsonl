{"id":"adv-001","category":"multi-tool","messages":[{"role":"system","content":"You are a travel assistant. Use tools when the answer needs live data."},{"role":"user","content":"What's the weather in Paris right now, and if it's 20 C there, what is that in Fahrenheit?"},{"role":"assistant","tool_calls":[{"type":"function","function":{"name":"weather_current","arguments":"{\"location\":\"Paris\"}"}},{"type":"function","function":{"name":"temperature_convert","arguments":"{\"value\":20,\"from_unit\":\"celsius\",\"to_unit\":\"fahrenheit\"}"}}]}],"tools":[{"type":"function","function":{"name":"weather_current","description":"Get the current weather for a location","parameters":{"type":"object","properties":{"location":{"type":"string"}},"required":["location"]}}},{"type":"function","function":{"name":"temperature_convert","description":"Convert a temperature between units","parameters":{"type":"object","properties":{"value":{"type":"number"},"from_unit":{"type":"string","enum":["celsius","fahrenheit","kelvin"]},"to_unit":{"type":"string","enum":["celsius","fahrenheit","kelvin"]}},"required":["value","from_unit","to_unit"]}}}],"notes":"Requires two sequential tool calls: one live lookup and one derived conversion."}
