{"id":"adv-024","category":"schema-edge","messages":[{"role":"system","content":"You reconcile records with optional IDs."},{"role":"user","content":"Update the record, and if there is no ID use the slug field instead."},{"role":"assistant","tool_calls":[{"type":"function","function":{"name":"record_update","arguments":"{\"slug\":\"llamactl-adversarial-v0\",\"payload\":{\"status\":\"ready\",\"priority\":3}}"}},{"type":"function","function":{"name":"record_update","arguments":"{\"id\":\"rec_42\",\"payload\":{\"status\":\"ready\",\"priority\":3}}"}}]}],"tools":[{"type":"function","function":{"name":"record_update","description":"Update a record by id or slug","parameters":{"type":"object","properties":{"id":{"type":"string"},"slug":{"type":"string"},"payload":{"type":"object","properties":{"status":{"type":"string"},"priority":{"type":"integer"}},"required":["status"]}},"anyOf":[{"required":["id"]},{"required":["slug"]}]}}}],"notes":"Optional ID versus slug plus nested payload creates a more brittle schema than a flat request."}
