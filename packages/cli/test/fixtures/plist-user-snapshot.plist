<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.llamactl.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/llamactl-agent</string>
    <string>agent</string>
    <string>serve</string>
    <string>--dir=/Users/alice/.llamactl-agent</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>ThrottleInterval</key><integer>10</integer>
  <key>StandardOutPath</key><string>/Users/alice/.llamactl-launchd-logs/stdout.log</string>
  <key>StandardErrorPath</key><string>/Users/alice/.llamactl-launchd-logs/stderr.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/usr/local/bin:/usr/bin</string>
    <key>DEV_STORAGE</key><string>/Users/alice/DevStorage</string>
  </dict>
</dict>
</plist>
