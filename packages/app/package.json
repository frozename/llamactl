{
  "name": "@llamactl/app",
  "version": "0.0.0",
  "description": "Electron dashboard for llamactl.",
  "author": "Alexandre Cordeiro <alexandre.s.b.cordeiro@gmail.com>",
  "type": "module",
  "main": "./out/main/index.cjs",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "typecheck": "tsc --noEmit",
    "package": "bun run build && electron-builder --config electron-builder.yml",
    "package:mac": "bun run build && electron-builder --config electron-builder.yml --mac",
    "package:mac:arm64": "bun run build && electron-builder --config electron-builder.yml --mac --arm64",
    "package:mac:x64": "bun run build && electron-builder --config electron-builder.yml --mac --x64",
    "package:dir": "bun run build && electron-builder --config electron-builder.yml --dir"
  },
  "dependencies": {
    "@llamactl/core": "workspace:*",
    "@llamactl/remote": "workspace:*",
    "@tanstack/react-query": "5.99.0",
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "@trpc/server": "11.16.0",
    "electron-trpc": "1.0.0-alpha.0",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "eventsource": "4.1.0",
    "superjson": "2.2.6",
    "undici": "7.18.0",
    "yaml": "2.8.3",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "7.3.2"
  }
}
