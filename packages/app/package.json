{
  "name": "@llamactl/app",
  "version": "0.0.0",
  "private": true,
  "description": "Electron dashboard for llamactl.",
  "type": "module",
  "main": "./out/main/index.cjs",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@llamactl/core": "workspace:*",
    "@llamactl/remote": "workspace:*",
    "@tanstack/react-query": "5.99.0",
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "@trpc/server": "11.16.0",
    "electron-trpc": "1.0.0-alpha.0",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "superjson": "2.2.6",
    "zod": "3.23.8",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "33.2.1",
    "electron-vite": "3.1.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "6.0.5"
  }
}
