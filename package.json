{
  "name": "llamactl",
  "version": "0.0.0",
  "description": "Local-first toolkit for running llama.cpp: discovery, benchmarks, candidate evaluation, shell + Electron control surfaces.",
  "repository": "https://github.com/frozename/llamactl",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cli": "bun run --cwd packages/cli src/bin.ts",
    "build:agent": "bun run packages/cli/src/bin.ts artifacts build-agent",
    "build:agent:all": "scripts/build-all-targets.sh",
    "prepare": "husky",
    "lint": "bun scripts/lint/no-cross-package-relative.ts && eslint . --max-warnings=0 && bun run typecheck:strict",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "bun run --cwd packages/core typecheck && bun run --cwd packages/policy typecheck && bun run --cwd packages/cli typecheck && bun run --cwd packages/app typecheck && bun run --cwd packages/remote typecheck && bun run --cwd packages/eval typecheck && bun run --cwd packages/agents typecheck && bun run --cwd packages/fleet-supervisor typecheck && bun run --cwd packages/mcp typecheck",
    "test": "zsh test/run-all.zsh",
    "test:core": "bun run --cwd packages/core test",
    "test:cli": "bun run --cwd packages/cli test",
    "test:shell": "zsh test/shell-smoke.zsh",
    "audit": "scripts/audit.sh diff",
    "audit:update": "scripts/audit.sh update",
    "audit:functional": "scripts/audit.sh functional",
    "typecheck:strict": "bun scripts/typecheck-strict.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "7.3.5"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,json,md,yml,yaml}": "prettier --check"
  }
}
